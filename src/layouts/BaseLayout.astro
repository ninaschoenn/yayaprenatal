---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Yaya Prenatal — Ganzheitliche Schwangerschaftsbegleitung Berlin',
  description = 'Blutanalysen, systemisches Coaching und persönliche Begleitung für deine Schwangerschaft. Heilpraktiker-Praxis in Friedrichshain, Berlin.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(site.socialImage.path, site.url);
---

<!doctype html>
<html lang={site.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#F7F3EE" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:width" content={String(site.socialImage.width)} />
    <meta property="og:image:height" content={String(site.socialImage.height)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />

    <!-- Structured Data: LocalBusiness -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MedicalBusiness",
      "name": site.name,
      "description": "Ganzheitliche Schwangerschaftsbegleitung mit Blutanalysen und systemischem Coaching",
      "url": site.url,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": site.legalContact.street,
        "postalCode": site.legalContact.postalCode,
        "addressLocality": site.legalContact.city,
        "addressRegion": site.business.region,
        "addressCountry": site.business.countryCode,
        "neighborhood": site.business.neighborhood
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "52.5388",
        "longitude": "13.4244"
      },
      "priceRange": site.business.priceRange,
      "medicalSpecialty": site.business.medicalSpecialty,
      "availableLanguage": site.business.availableLanguages,
      "email": site.publicContact.email,
      "telephone": site.publicContact.phone,
      "image": socialImageURL.toString()
    })} />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
