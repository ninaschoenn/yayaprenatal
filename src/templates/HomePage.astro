---
import AboutNina from '../components/AboutNina.astro';
import BodyMap from '../components/BodyMap.astro';
import CTASection from '../components/CTASection.astro';
import CoachingSection from '../components/CoachingSection.astro';
import Footer from '../components/Footer.astro';
import ForYou from '../components/ForYou.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Journey from '../components/Journey.astro';
import Packages from '../components/Packages.astro';
import Testimonials from '../components/Testimonials.astro';
import { homeContent } from '../data/home-content';
import { getAlternateLinks, sectionIds, type Locale } from '../data/i18n';
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = homeContent[locale];
const ids = sectionIds[locale];
---

<BaseLayout
  locale={locale}
  title={content.meta.title}
  description={content.meta.description}
  alternates={getAlternateLinks('home')}
>
  <Header locale={locale} pageKey="home" />
  <main>
    <Hero content={content.hero} contactId={ids.contact} />
    <ForYou content={content.forYou} />
    <section class="bg-pearl px-4 pt-20 pb-6 md:px-12 md:pt-28 md:pb-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-5 text-[12px] font-medium uppercase tracking-[3px] text-terra">
          {content.offer.eyebrow}
        </p>
        <h2 class="mb-12 font-serif text-[40px] font-light leading-[1.1] text-deep md:mb-16 md:text-[64px]">
          <em class="italic text-terra">{content.offer.title}</em>
        </h2>
        <p class="mx-auto max-w-2xl font-serif text-xl font-light italic leading-[1.6] text-deep md:text-2xl">
          {content.babyFirst.pullQuote}
        </p>
      </div>
    </section>
    <BodyMap content={content.bodyMap} step="01" />
    <CoachingSection content={content.coaching} step="02" />
    <Journey content={content.journey} />
    <Packages id={ids.packages} content={content.packages} />
    <AboutNina id={ids.about} content={content.about} />
    <Testimonials content={content.testimonials} />
    <CTASection id={ids.contact} content={content.cta} disclaimer={content.disclaimer} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
