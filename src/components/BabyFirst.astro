---
import type { HomeContent } from '../data/home-content';

interface Props {
  content: HomeContent['babyFirst'];
}

const { content } = Astro.props;
---

<section class="bg-cream px-4 py-12 text-center md:px-12 md:py-[72px]">
  <div class="mx-auto max-w-[560px]">
    <p class="mb-4 font-serif text-[20px] font-light leading-[1.6] text-deep md:text-[26px]">
      {content.intro}{' '}
      <em class="italic text-terra">{content.introAccent}</em>
    </p>

    <p class="mb-4 text-sm font-light leading-[1.8] text-subtle md:text-base">
      {content.body[0]}
    </p>

    <p class="text-sm font-light leading-[1.8] text-subtle md:text-base">
      {content.body[1]} <em class="italic text-terra">{content.bodyAccent}</em> {content.bodySuffix}
    </p>
  </div>
</section>
