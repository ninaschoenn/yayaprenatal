---
import type { HomeContent } from '../data/home-content';

interface Props {
  content: HomeContent['howItWorks'];
}

const { content } = Astro.props;
---

<section class="bg-pearl px-4 py-16 md:px-12 md:py-24">
  <div class="mx-auto max-w-3xl">
    <p class="mb-4 font-sans text-xs uppercase tracking-widest text-terra">
      {content.eyebrow}
    </p>

    <h2 class="mb-3 font-serif text-3xl leading-tight text-ink md:text-5xl">
      {content.title}
    </h2>

    <p class="mb-12 text-sm font-light text-subtle">
      {content.noteBefore}<span class="font-medium text-terra">{content.noteAccent}</span>{content.noteAfter}
    </p>

    <div class="relative max-w-[640px]">
      <div class="absolute left-6 top-3 bottom-3 w-px bg-terra/25" aria-hidden="true"></div>

      <div class="space-y-10">
        {content.features.map((feature) => (
          <div class="relative flex items-start gap-6">
            <span
              class="relative z-10 flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-cream text-xl leading-none ring-1 ring-terra/30"
              aria-hidden="true"
            >
              {feature.icon}
            </span>
            <div class="pt-2.5">
              <h3 class="mb-1.5 font-serif text-lg font-light leading-snug text-deep md:text-xl">
                {feature.title}
              </h3>
              <p class="text-sm leading-relaxed text-subtle font-light">{feature.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
