---
import type { HomeContent } from '../data/home-content';

interface Props {
  content: HomeContent['howItWorks'];
}

const { content } = Astro.props;
---

<section class="bg-pearl px-4 py-16 md:px-12 md:py-24">
  <div class="mx-auto max-w-3xl">
    <p class="mb-4 font-sans text-xs uppercase tracking-widest text-terra">
      {content.eyebrow}
    </p>

    <h2 class="mb-3 font-serif text-3xl leading-tight text-ink md:text-5xl">
      {content.title}
    </h2>

    <p class="mb-12 text-sm font-light text-subtle">
      {content.noteBefore}<span class="font-medium text-terra">{content.noteAccent}</span>{content.noteAfter}
    </p>

    <div class="grid max-w-[700px] grid-cols-1 gap-5 md:grid-cols-2">
      {content.features.map((feature) => (
        <div class="flex items-start gap-4 rounded-md bg-cream p-6">
          <span class="mt-0.5 shrink-0 text-2xl leading-none" aria-hidden="true">
            {feature.icon}
          </span>
          <div>
            <h3 class="mb-2 text-sm leading-snug font-semibold text-ink">
              {feature.title}
            </h3>
            <p class="text-sm leading-relaxed text-subtle">{feature.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
