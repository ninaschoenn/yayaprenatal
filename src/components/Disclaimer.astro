---
import type { HomeContent } from '../data/home-content';

interface Props {
  content: HomeContent['disclaimer'];
}

const { content } = Astro.props;
---

<section class="border-t border-warm bg-cream px-4 py-8 md:px-12 md:py-10">
  <div class="mx-auto max-w-[600px] text-center">
    <p class="font-serif text-sm font-light leading-[1.8] text-subtle italic md:text-base">
      {content}
    </p>
  </div>
</section>
