---
import { site } from '../data/site';

const contacts = [
  { label: 'Email', value: site.publicContact.email, href: site.publicContact.emailHref },
  { label: 'Telefon', value: site.publicContact.phone, href: site.publicContact.phoneHref },
  { label: 'Adresse', value: site.publicContact.addressShort },
];
---

<section id="kontakt" class="bg-cream py-16 md:py-24 px-4 md:px-12 text-center">
  <div class="max-w-xl mx-auto">
    <h2 class="font-serif text-[32px] md:text-[52px] font-light text-deep mb-5 leading-[1.2]">
      Bereit für <em class="italic text-terra">mehr</em>?
    </h2>

    <p class="text-base leading-[1.7] text-subtle font-light mb-10">
      Du kannst mir jederzeit schreiben und wir schauen gemeinsam, ob diese Form der Begleitung zu dir passt.
    </p>

    <a
      href={site.publicContact.emailHref}
      class="inline-block px-12 py-[18px] bg-terra text-pearl text-[13px] tracking-[2px] uppercase font-medium no-underline hover:bg-deep transition-colors duration-300"
    >
      Schreib Mir
    </a>
    <p class="text-[13px] text-subtle font-light mt-3">Ich antworte dir persönlich.</p>

    <div class="mt-12 flex justify-center gap-6 md:gap-12 flex-wrap">
      {contacts.map((c) => (
        <div class="text-center">
          <p class="text-[10px] tracking-widest uppercase text-terra mb-1">{c.label}</p>
          {c.href ? (
            <a href={c.href} class="text-[14px] text-ink no-underline hover:text-terra transition-colors duration-200">
              {c.value}
            </a>
          ) : (
            <p class="text-[14px] text-ink">{c.value}</p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
