---
import type { HomeContent } from '../data/home-content';
import { site } from '../data/site';

interface Props {
  id: string;
  content: HomeContent['cta'];
}

const { id, content } = Astro.props;

const contacts = [
  { label: content.labels.email, value: site.publicContact.email, href: site.publicContact.emailHref },
  { label: content.labels.phone, value: site.publicContact.phone, href: site.publicContact.phoneHref },
  { label: content.labels.address, value: site.publicContact.addressShort },
];
---

<section id={id} class="bg-cream px-4 py-16 text-center md:px-12 md:py-24">
  <div class="mx-auto max-w-xl">
    <h2 class="mb-5 font-serif text-[32px] font-light leading-[1.2] text-deep md:text-[52px]">
      {content.titlePrefix} <em class="italic text-terra">{content.titleAccent}</em>{content.titleSuffix}
    </h2>

    <p class="mb-10 text-base font-light leading-[1.7] text-subtle">
      {content.body}
    </p>

    <a
      href={site.publicContact.emailHref}
      class="inline-block bg-terra px-12 py-[18px] text-[13px] font-medium uppercase tracking-[2px] text-pearl no-underline transition-colors duration-300 hover:bg-deep"
    >
      {content.buttonLabel}
    </a>
    <p class="mt-3 text-[13px] font-light text-subtle">{content.responseLabel}</p>

    <div class="mt-12 flex flex-wrap justify-center gap-6 md:gap-12">
      {contacts.map((contact) => (
        <div class="text-center">
          <p class="mb-1 text-[10px] uppercase tracking-widest text-terra">{contact.label}</p>
          {contact.href ? (
            <a href={contact.href} class="text-[14px] text-ink no-underline transition-colors duration-200 hover:text-terra">
              {contact.value}
            </a>
          ) : (
            <p class="text-[14px] text-ink">{contact.value}</p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
