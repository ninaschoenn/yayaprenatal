---
import type { HomeContent } from '../data/home-content';
import { site } from '../data/site';

interface Props {
  id: string;
  content: HomeContent['cta'];
  disclaimer: HomeContent['disclaimer'];
}

const { id, content, disclaimer } = Astro.props;

const contacts = [
  {
    label: content.labels.email,
    value: site.publicContact.email,
    copyValue: site.publicContact.email,
  },
  {
    label: content.labels.phone,
    value: site.publicContact.phone,
    copyValue: site.publicContact.phone,
  },
  {
    label: content.labels.address,
    value: site.publicContact.addressFull,
    copyValue: site.publicContact.addressFull,
  },
];
---

<section id={id} class="bg-cream px-4 pt-14 pb-10 text-center md:px-12 md:pt-20 md:pb-14">
  <div class="mx-auto max-w-3xl">
    <h2 class="mb-4 font-serif text-[26px] font-light leading-[1.2] text-deep md:text-[36px]">
      {content.titlePrefix} <em class="italic text-terra">{content.titleAccent}</em>{content.titleSuffix}
    </h2>

    <p class="mx-auto mb-10 max-w-xl text-[15px] font-light leading-[1.7] text-subtle md:mb-12">
      {content.body}
    </p>

    <div class="mx-auto grid w-full max-w-2xl grid-cols-1 gap-6 md:grid-cols-3 md:gap-8">
      {contacts.map((contact) => (
        <div class="flex flex-col items-center text-center">
          <p class="mb-1.5 text-[10px] uppercase tracking-widest text-terra">{contact.label}</p>
          <button
            type="button"
            class="group relative inline-flex cursor-pointer items-center justify-center border-0 bg-transparent p-0 text-[13px] font-light text-ink transition-all duration-200 hover:text-terra focus:outline-none focus-visible:text-terra md:text-[14px]"
            data-copy-target
            data-copy-value={contact.copyValue}
            aria-label={`${contact.label}: ${contact.value}. ${content.labels.copy}`}
          >
            <span data-copy-text>{contact.value}</span>
            <span
              aria-hidden="true"
              data-copy-feedback
              class="pointer-events-none absolute left-1/2 top-full mt-1 -translate-x-1/2 translate-y-0 whitespace-nowrap text-[10px] uppercase tracking-[1.5px] text-terra opacity-0 transition-all duration-200"
            >
              {content.labels.copied}
            </span>
          </button>
        </div>
      ))}
    </div>

    <p class="mx-auto mt-14 max-w-[620px] font-serif text-[13px] font-light italic leading-[1.8] text-subtle/80 md:mt-16 md:text-sm">
      {disclaimer}
    </p>
  </div>
</section>

<script is:inline>
  const copyTargets = document.querySelectorAll('[data-copy-target]');

  copyTargets.forEach((button) => {
    const feedback = button.querySelector('[data-copy-feedback]');
    const text = button.querySelector('[data-copy-text]');
    let resetTimer;

    button.addEventListener('click', async () => {
      const value = button.getAttribute('data-copy-value');

      if (!value) {
        return;
      }

      try {
        await navigator.clipboard.writeText(value);
        window.clearTimeout(resetTimer);
        button.classList.add('text-terra', 'scale-[1.01]');
        feedback?.classList.remove('opacity-0', 'translate-y-0');
        feedback?.classList.add('opacity-100', 'translate-y-0.5');
        text?.classList.add('underline', 'underline-offset-4');

        resetTimer = window.setTimeout(() => {
          button.classList.remove('text-terra', 'scale-[1.01]');
          feedback?.classList.add('opacity-0', 'translate-y-0');
          feedback?.classList.remove('opacity-100', 'translate-y-0.5');
          text?.classList.remove('underline', 'underline-offset-4');
        }, 1200);
      } catch {
        button.classList.remove('text-terra', 'scale-[1.01]');
      }
    });
  });
</script>
