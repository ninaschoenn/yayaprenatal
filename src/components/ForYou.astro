<!-- Neuer Abschnitt: Für wen ist das Angebot -->
<section class="bg-cream py-16 md:py-24 px-4 md:px-12">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row gap-8 md:gap-16">

      <!-- Linke Spalte: Überschrift -->
      <div class="md:w-[40%] md:sticky md:top-32 md:self-start">
        <p class="text-[12px] tracking-[3px] uppercase text-terra mb-4 font-medium">
          Für wen
        </p>
        <h2 class="font-serif text-[28px] md:text-[42px] font-light leading-[1.2] text-deep">
          Wann diese Begleitung für dich
          <em class="italic text-terra">sinnvoll ist.</em>
        </h2>
      </div>

      <!-- Rechte Spalte: Textblöcke -->
      <div class="md:w-[60%] space-y-8 text-[15px] md:text-base leading-[1.9] text-subtle font-light">
        <p class="border-l-2 border-warm pl-5">
          Du möchtest deine Blutwerte wirklich verstehen — nicht nur „im Normbereich" sein.
        </p>
        <p class="border-l-2 border-warm pl-5">
          Du fragst dich, ob dein Körper optimal versorgt ist, oder ob etwas übersehen wird.
        </p>
        <p class="border-l-2 border-warm pl-5">
          Du willst Supplemente nicht „auf Verdacht" nehmen, sondern wissen, was du wirklich brauchst.
        </p>
        <p class="border-l-2 border-warm pl-5">
          Du spürst, dass deine Schwangerschaft einen eigenen Raum verdient.
        </p>
      </div>

    </div>
  </div>
</section>
