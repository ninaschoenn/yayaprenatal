---
import type { HomeContent } from '../data/home-content';

interface Props {
  content: HomeContent['forYou'];
}

const { content } = Astro.props;
---

<section class="bg-cream px-4 py-16 md:px-12 md:py-24">
  <div class="mx-auto max-w-5xl">
    <div class="flex flex-col gap-8 md:flex-row md:gap-16">
      <div class="md:sticky md:top-32 md:w-[40%] md:self-start">
        <p class="mb-4 text-[12px] font-medium uppercase tracking-[3px] text-terra">
          {content.eyebrow}
        </p>
        <h2 class="font-serif text-[28px] font-light leading-[1.2] text-deep md:text-[42px]">
          {content.titlePrefix}{' '}
          <em class="italic text-terra">{content.titleAccent}</em>
        </h2>
      </div>

      <div class="space-y-8 text-[15px] font-light leading-[1.9] text-subtle md:w-[60%] md:text-base">
        {content.items.map((item) => (
          <p class="border-l-2 border-warm pl-5">{item}</p>
        ))}
        <p class="pl-5 font-medium text-deep">{content.closing}</p>
      </div>
    </div>
  </div>
</section>
