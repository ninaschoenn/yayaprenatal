---
import type { HomeContent } from '../data/home-content';

interface Props {
  content: HomeContent['gapStats'];
}

const { content } = Astro.props;
---

<section class="bg-pearl px-4 py-16 md:px-12 md:py-24">
  <div class="mx-auto max-w-5xl">
    <p class="mb-4 text-[12px] font-medium uppercase tracking-[3px] text-terra">
      {content.eyebrow}
    </p>

    <h2 class="mb-4 font-serif text-[28px] font-light leading-[1.2] text-deep md:text-[48px]">
      {content.titlePrefix}<br />
      <em class="italic text-terra">{content.titleAccent}</em>
    </h2>

    <p class="mb-10 max-w-[540px] text-sm font-light leading-[1.7] text-subtle md:mb-14 md:text-base">
      {content.intro}
    </p>

    <div class="mb-10 grid grid-cols-1 gap-4 md:mb-14 md:grid-cols-3 md:gap-6">
      {content.stats.map((stat) => (
        <div class={`rounded bg-cream p-6 border-t-[3px] md:p-8 ${stat.accent}`}>
          <div class={`font-serif text-[48px] font-light leading-none md:text-[56px] ${stat.numColor}`}>
            {stat.num}
          </div>
          <div class="mt-1 mb-3 text-[13px] font-semibold text-ink">
            {stat.unit}
          </div>
          <p class="text-[14px] font-light leading-[1.7] text-subtle">
            {stat.text}
          </p>
        </div>
      ))}
    </div>

    <div class="max-w-[540px] space-y-6">
      {content.steps.map((step) => (
        <div class="flex items-start gap-4">
          <span class={`mt-1 shrink-0 font-serif text-lg leading-none ${step.numberClass}`}>
            {step.number}
          </span>
          <div>
            <p class={`text-sm font-semibold ${step.titleClass}`}>{step.title}</p>
            <p class="text-[14px] font-light leading-[1.7] text-subtle">{step.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
