---
import { pageRoutes, type Locale, uiCopy } from '../data/i18n';
import { site } from '../data/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
const footerCopy = uiCopy[locale].footer;
const routes = pageRoutes[locale];
---

<footer class="bg-deep px-4 py-8 md:px-12 md:py-10">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-6 md:grid md:grid-cols-[1fr_auto_1fr] md:items-center">
    <a href={routes.home} class="no-underline md:justify-self-start">
      <img
        src={site.branding.logoPath}
        alt="Yaya Prenatal"
        width="2000"
        height="2000"
        loading="lazy"
        decoding="async"
        class="h-[48px] w-auto"
      />
    </a>

    <div class="flex flex-wrap justify-center gap-6 text-[12px] text-blush md:justify-self-center">
      <a href={routes.imprint} class="text-blush no-underline transition-colors duration-200 hover:text-cream">
        {footerCopy.imprintLabel}
      </a>
      <a href={routes.privacy} class="text-blush no-underline transition-colors duration-200 hover:text-cream">
        {footerCopy.privacyLabel}
      </a>
    </div>

    <div class="text-center text-[12px] leading-relaxed text-blush md:justify-self-end md:text-right">
      <div>&copy; {year} {site.name}</div>
      <div>{site.business.neighborhood}, Berlin</div>
    </div>
  </div>
</footer>
