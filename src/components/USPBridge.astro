---
import type { HomeContent } from '../data/home-content';

interface Props {
  content: HomeContent['uspBridge'];
}

const { content } = Astro.props;
---

<section class="bg-pearl px-4 py-12 text-center md:px-12 md:py-16">
  <div class="mx-auto max-w-[600px]">
    <p class="font-serif text-[20px] font-light leading-[1.6] text-deep md:text-[26px]">
      {content.prefix}<br />
      {content.items.map((item) => (
        <span class="text-terra">{item} </span>
      ))}
    </p>
  </div>
</section>
