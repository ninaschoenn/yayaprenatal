---
import type { HomeContent } from '../data/home-content';

interface Props {
  content: HomeContent['bodyMap'];
}

const { content } = Astro.props;
---

<section class="relative overflow-hidden px-4 py-20 md:px-12 md:py-30">
  <div class="absolute top-0 left-1/2 h-[3px] w-15 -translate-x-1/2 rounded-full bg-terra" />

  <div class="mx-auto max-w-5xl">
    <div class="mb-8 text-center md:mb-12">
      <p class="mb-4 text-xs font-medium uppercase tracking-[3px] text-terra">
        {content.eyebrow}
      </p>
      <h2 class="mb-3 font-serif text-3xl font-light leading-tight text-deep md:text-5xl">
        {content.title}
      </h2>
      <p class="mx-auto mb-4 max-w-lg font-serif text-lg font-light leading-relaxed text-deep opacity-80 md:text-xl">
        {content.intro}
      </p>
      <p class="mx-auto max-w-lg text-sm font-light leading-relaxed text-subtle md:text-base">
        {content.description}
      </p>
    </div>

    <div class="mb-6 flex flex-wrap justify-center gap-3 md:mb-10 md:gap-6">
      {Object.values(content.categories).map((category) => (
        <div class="flex items-center gap-1.5">
          <div
            class="h-2.5 w-2.5 rounded-full"
            style={`background:${category.color}; box-shadow: 0 0 6px ${category.color}44;`}
          />
          <span class="text-xs font-medium tracking-wide text-subtle">{category.label}</span>
        </div>
      ))}
    </div>

    <div data-body-map-root class="relative mx-auto w-full max-w-sm md:max-w-2xl">
    <svg
      viewBox="0 0 100 105"
      class="body-map-figure h-auto w-full transition-opacity duration-300"
      aria-labelledby="body-map-title body-map-description"
      role="img"
    >
      <title id="body-map-title">{content.title}</title>
      <desc id="body-map-description">{content.description}</desc>
      <defs>
        <radialGradient id="bodyGlow" cx="50%" cy="45%" r="35%">
          <stop offset="0%" stop-color="#C4856C" stop-opacity="0.12" />
          <stop offset="100%" stop-color="#C4856C" stop-opacity="0" />
        </radialGradient>
        <radialGradient id="bellyGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#C4856C" stop-opacity="0.15" />
          <stop offset="100%" stop-color="#C4856C" stop-opacity="0" />
        </radialGradient>
      </defs>

      <ellipse cx="50" cy="48" rx="16" ry="32" fill="url(#bodyGlow)" />
      <ellipse cx="50" cy="7.5" rx="3.8" ry="4.5" fill="none" stroke="#5C3D2E" stroke-width="0.35" opacity="0.25" />
      <path d="M46.5 6 Q47 3 50 2.5 Q53 3 53.5 6" fill="none" stroke="#5C3D2E" stroke-width="0.25" opacity="0.15" />
      <path d="M48.5 12 L48.8 15 M51.5 12 L51.2 15" fill="none" stroke="#5C3D2E" stroke-width="0.25" opacity="0.15" />
      <path d="M42 18 Q46 15 50 15 Q54 15 58 18" fill="none" stroke="#5C3D2E" stroke-width="0.35" opacity="0.22" />
      <path d="M39 21 Q37 27 36 33 Q35.5 36 36 38" fill="none" stroke="#5C3D2E" stroke-width="0.28" opacity="0.15" />
      <path d="M61 21 Q63 27 62 33 Q60 38 57 42" fill="none" stroke="#5C3D2E" stroke-width="0.28" opacity="0.15" />
      <path d="M39 21 L38 28 Q37 35 37.5 42 Q38 50 40 56 Q41 60 42 65" fill="none" stroke="#5C3D2E" stroke-width="0.35" opacity="0.22" />
      <path d="M61 21 L60 28 Q59 32 58 36" fill="none" stroke="#C4856C" stroke-width="0.35" opacity="0.22" />
      <path d="M38 28 Q39 36 43 44 Q47 52 50 54 Q53 52 57 44 Q61 36 60 28" fill="none" stroke="#C4856C" stroke-width="0.3" opacity="0.25" stroke-dasharray="1.2 0.8" />
      <path d="M58 36 Q60 44 60 50 Q59 56 57 62 Q56 65 55 68" fill="none" stroke="#5C3D2E" stroke-width="0.35" opacity="0.22" />
      <path d="M42 65 Q43 68 44 72 Q44.5 78 45 85 Q45 90 45 95" fill="none" stroke="#5C3D2E" stroke-width="0.3" opacity="0.18" />
      <path d="M55 68 Q55 72 54.5 78 Q54 85 54 90 Q54 93 54 95" fill="none" stroke="#5C3D2E" stroke-width="0.3" opacity="0.18" />
      <ellipse cx="50" cy="44" rx="6.5" ry="7" fill="url(#bellyGlow)" stroke="#C4856C" stroke-width="0.25" opacity="0.18" stroke-dasharray="1.5 1" />
      <circle cx="49" cy="42" r="2.5" fill="none" stroke="#C4856C" stroke-width="0.2" opacity="0.25" />
      <path d="M50.5 44 Q52 46 51 48" fill="none" stroke="#C4856C" stroke-width="0.15" opacity="0.2" />

      {content.markers.map((marker) => {
        const category = content.categories[marker.cat];
        const labelX = marker.side === 'L' ? 2 : 98;
        const elbowX = marker.side === 'L' ? 22 : 78;
        const textAnchor = marker.side === 'L' ? 'start' : 'end';
        const dotX = marker.side === 'L' ? 1 : 99;

        return (
          <g
            class="body-marker transition-opacity duration-200 focus:outline-none"
            data-marker-id={marker.id}
            tabindex="0"
            role="button"
            aria-controls={`body-map-panel-${marker.id}`}
            aria-pressed="false"
            aria-label={marker.label}
            style="cursor:pointer"
          >
            <rect
              x={marker.side === 'L' ? 0 : 60}
              y={marker.y - 4}
              width="40"
              height="9"
              fill="transparent"
            />
            <circle
              class="body-marker-ring transition-all duration-200"
              data-marker-ring
              cx={marker.x}
              cy={marker.y}
              r="4"
              fill={category.color}
              opacity="0.08"
            />
            <circle
              class="body-marker-dot transition-all duration-200"
              data-marker-dot
              cx={marker.x}
              cy={marker.y}
              r="1.4"
              fill={category.color}
              opacity="0.5"
            />
            <path
              class="body-marker-line transition-all duration-200"
              data-marker-line
              d={`M${marker.x} ${marker.y} L${elbowX} ${marker.y}`}
              fill="none"
              stroke="#7A6B60"
              stroke-width="0.18"
              opacity="0.25"
            />
            <path
              class="body-marker-line transition-all duration-200"
              data-marker-line
              d={`M${elbowX} ${marker.y} L${labelX} ${marker.y}`}
              fill="none"
              stroke="#7A6B60"
              stroke-width="0.12"
              opacity="0.15"
            />
            <circle
              class="body-marker-label-dot transition-all duration-200"
              data-marker-label-dot
              cx={dotX}
              cy={marker.y}
              r="1"
              fill={category.color}
              opacity="0.6"
            />
            <text
              x={marker.side === 'L' ? 4 : 96.5}
              y={marker.y - 1.2}
              text-anchor={textAnchor}
              fill="#7A6B60"
              font-size="2.8"
              font-weight="400"
              font-family="DM Sans, sans-serif"
              opacity="0.8"
              data-marker-title
            >
              {marker.label}
            </text>
            <text
              x={marker.side === 'L' ? 4 : 96.5}
              y={marker.y + 2}
              text-anchor={textAnchor}
              fill="#7A6B60"
              font-size="1.9"
              font-family="DM Sans, sans-serif"
              opacity="0.5"
              data-marker-subtitle
            >
              {marker.sub}
            </text>
          </g>
        );
      })}
    </svg>

    {content.markers.map((marker) => {
      const category = content.categories[marker.cat];
      return (
        <div
          id={`body-map-panel-${marker.id}`}
          class="body-map-panel absolute top-1/2 left-1/2 z-10 hidden w-[92%] max-w-lg -translate-x-1/2 -translate-y-1/2 rounded-[1.9rem] bg-pearl p-5 md:w-[85%] md:p-7"
          data-panel-id={marker.id}
          role="dialog"
          aria-modal="false"
          aria-hidden="true"
          aria-labelledby={`body-map-panel-title-${marker.id}`}
          style={`box-shadow: 0 8px 40px rgba(92,61,46,0.18); border-left: 4px solid ${category.color};`}
        >
          <div class="mb-3.5 flex items-start justify-between">
            <div>
              <div class="mb-1 flex items-center gap-2.5">
                <div class="h-2.5 w-2.5 rounded-full" style={`background:${category.color};`} />
                <span
                  class="text-[10px] font-medium uppercase tracking-[1.5px]"
                  style={`color:${category.color};`}
                >
                  {category.label}
                </span>
              </div>
              <h3
                id={`body-map-panel-title-${marker.id}`}
                class="font-serif text-xl font-light text-deep md:text-2xl"
              >
                {marker.label}
              </h3>
              <p class="mt-0.5 text-xs text-terra">{marker.sub}</p>
            </div>
            <button
              type="button"
              class="body-map-close flex h-9 w-9 cursor-pointer items-center justify-center rounded-full bg-black/[0.04] text-xl leading-none text-subtle transition-colors hover:bg-black/[0.08]"
              data-close-panel
              aria-label={content.closeLabel}
            >
              &times;
            </button>
          </div>

          <div class="grid grid-cols-1 gap-3 md:grid-cols-2 md:gap-4">
            <div class="rounded-[1.2rem] p-3.5" style="background: rgba(196,133,108,0.1);">
              <p class="mb-1.5 text-[10px] font-semibold uppercase tracking-[2px] text-terra">
                {content.detailLabels.mother}
              </p>
              <p class="text-xs font-light leading-relaxed text-subtle">
                {marker.mother}
              </p>
            </div>
            <div class="rounded-[1.2rem] p-3.5" style="background: rgba(212,168,154,0.1);">
              <p class="mb-1.5 text-[10px] font-semibold uppercase tracking-[2px] text-terra">
                {content.detailLabels.baby}
              </p>
              <p class="text-xs font-light leading-relaxed text-subtle">
                {marker.baby}
              </p>
            </div>
          </div>

          <div
            class="mt-3 rounded-[1.2rem] p-2.5 px-3.5"
            style="background: rgba(220,38,38,0.06); border-left: 2px solid rgba(220,38,38,0.4);"
          >
            <p class="mb-1 text-[10px] font-semibold uppercase tracking-[2px] text-red-800">
              {content.detailLabels.gap}
            </p>
            <p class="text-xs font-light leading-snug text-red-900">{marker.gap}</p>
          </div>
        </div>
      );
    })}
    </div>

    <p data-body-map-hint class="mt-6 text-center text-sm font-light text-subtle opacity-70">
      {content.hint}
    </p>
  </div>
</section>

<script is:inline>
  const roots = document.querySelectorAll('[data-body-map-root]');

  roots.forEach((root) => {
    const figure = root.querySelector('.body-map-figure');
    const markers = Array.from(root.querySelectorAll('[data-marker-id]'));
    const panels = Array.from(root.querySelectorAll('[data-panel-id]'));
    const hint = root.parentElement?.querySelector('[data-body-map-hint]');
    let activeId = null;

    const applyMarkerState = (marker, isActive) => {
      const ring = marker.querySelector('[data-marker-ring]');
      const dot = marker.querySelector('[data-marker-dot]');
      const lines = marker.querySelectorAll('[data-marker-line]');
      const labelDot = marker.querySelector('[data-marker-label-dot]');
      const title = marker.querySelector('[data-marker-title]');
      const subtitle = marker.querySelector('[data-marker-subtitle]');
      const activeColor = ring?.getAttribute('fill') ?? '#C4856C';

      marker.setAttribute('aria-pressed', isActive ? 'true' : 'false');

      if (ring) {
        ring.setAttribute('opacity', isActive ? '0.12' : '0.08');
        ring.setAttribute('r', isActive ? '5' : '4');
      }

      if (dot) {
        dot.setAttribute('opacity', isActive ? '1' : '0.5');
        dot.setAttribute('r', isActive ? '2' : '1.4');
      }

      lines.forEach((line, index) => {
        line.setAttribute('stroke', isActive ? activeColor : '#7A6B60');
        line.setAttribute('opacity', isActive ? (index === 0 ? '0.9' : '0.6') : index === 0 ? '0.25' : '0.15');
        line.setAttribute('stroke-width', isActive ? (index === 0 ? '0.4' : '0.25') : index === 0 ? '0.18' : '0.12');
      });

      if (labelDot) {
        labelDot.setAttribute('opacity', isActive ? '1' : '0.6');
      }

      if (title) {
        title.setAttribute('fill', isActive ? '#5C3D2E' : '#7A6B60');
        title.setAttribute('font-size', isActive ? '3.2' : '2.8');
        title.setAttribute('font-weight', isActive ? '600' : '400');
        title.setAttribute('opacity', isActive ? '1' : '0.8');
      }

      if (subtitle) {
        subtitle.setAttribute('fill', isActive ? activeColor : '#7A6B60');
        subtitle.setAttribute('opacity', isActive ? '0.9' : '0.5');
      }
    };

    const closePanels = () => {
      activeId = null;
      if (figure) {
        figure.style.opacity = '1';
      }
      hint?.classList.remove('hidden');

      markers.forEach((marker) => applyMarkerState(marker, false));
      panels.forEach((panel) => {
        panel.classList.add('hidden');
        panel.setAttribute('aria-hidden', 'true');
      });
    };

    const openPanel = (id) => {
      const selectedMarker = markers.find((marker) => marker.getAttribute('data-marker-id') === id);
      const selectedPanel = panels.find((panel) => panel.getAttribute('data-panel-id') === id);

      if (!selectedMarker || !selectedPanel) {
        closePanels();
        return;
      }

      activeId = id;
      if (figure) {
        figure.style.opacity = '0.15';
      }
      hint?.classList.add('hidden');

      markers.forEach((marker) => {
        applyMarkerState(marker, marker === selectedMarker);
      });

      panels.forEach((panel) => {
        const isSelected = panel === selectedPanel;
        panel.classList.toggle('hidden', !isSelected);
        panel.setAttribute('aria-hidden', isSelected ? 'false' : 'true');
      });

      selectedPanel.querySelector('[data-close-panel]')?.focus();
    };

    markers.forEach((marker) => {
      marker.addEventListener('click', () => {
        const id = marker.getAttribute('data-marker-id');
        if (!id) {
          return;
        }

        if (activeId === id) {
          closePanels();
          return;
        }

        openPanel(id);
      });

      marker.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') {
          return;
        }

        event.preventDefault();
        const id = marker.getAttribute('data-marker-id');
        if (!id) {
          return;
        }

        if (activeId === id) {
          closePanels();
          return;
        }

        openPanel(id);
      });
    });

    panels.forEach((panel) => {
      panel.querySelector('[data-close-panel]')?.addEventListener('click', () => {
        closePanels();
      });
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closePanels();
      }
    });
  });
</script>
