---
import type { HomeContent } from '../data/home-content';

interface Props {
  content: HomeContent['testimonials'];
}

const { content } = Astro.props;
---

<section class="bg-deep px-4 py-16 md:px-12 md:py-24">
  <div class="mx-auto max-w-5xl">
    <p class="mb-4 font-sans text-xs uppercase tracking-widest text-blush">
      {content.eyebrow}
    </p>

    <h2 class="mb-12 font-serif text-[28px] font-light text-cream md:text-[40px]">
      {content.title}
    </h2>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
      {content.items.map((item) => (
        <div class="flex flex-col rounded-[1.8rem] border-l-[3px] border-terra bg-white/[0.06] p-5 md:p-7">
          <p class="mb-3 text-[9px] font-medium uppercase tracking-widest text-terra">
            {item.tag}
          </p>
          <p class="mb-4 flex-1 font-serif text-[15px] font-light italic leading-[1.7] text-cream md:text-base">
            &bdquo;{item.quote}&ldquo;
          </p>
          <p class="text-[12px] tracking-wider text-blush">
            {item.name}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
