---
import type { HomeContent } from '../data/home-content';

interface Props {
  content: HomeContent['journey'];
}

const { content } = Astro.props;
---

<section class="bg-cream px-4 py-16 md:px-12 md:py-24">
  <div class="mx-auto max-w-5xl">
    <p class="mb-4 font-sans text-xs uppercase tracking-widest text-terra">
      {content.eyebrow}
    </p>

    <h2 class="mb-6 font-serif text-3xl leading-tight text-ink md:text-5xl">
      {content.titlePrefix}<br />
      <em class="italic text-terra">{content.titleAccent}</em>
    </h2>

    <p class="mb-16 max-w-[700px] text-base leading-relaxed text-subtle md:text-lg">
      {content.intro}
    </p>

    <div class="mb-16 md:mb-24">
      <h3 class="mb-8 font-serif text-xl italic text-terra md:text-2xl">
        {content.rhythm.heading}
      </h3>

      <div class="relative max-w-[760px]">
        <div class="absolute left-6 top-3 bottom-3 w-px bg-terra/25 md:hidden" aria-hidden="true"></div>

        <div class="grid gap-8 md:grid-cols-2 md:gap-x-10 md:gap-y-10">
          {content.rhythm.features.map((feature) => (
            <div class="relative flex items-start gap-5">
              <span
                class="relative z-10 flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-pearl text-xl leading-none ring-1 ring-terra/30"
                aria-hidden="true"
              >
                {feature.icon}
              </span>
              <div class="pt-2.5">
                <h4 class="mb-1.5 font-serif text-lg font-light leading-snug text-deep md:text-xl">
                  {feature.title}
                </h4>
                <p class="text-sm font-light leading-relaxed text-subtle">{feature.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div>
      <h3 class="mb-8 font-serif text-xl italic text-terra md:text-2xl">
        {content.arc.heading}
      </h3>

      <div class="flex flex-col md:hidden">
        {content.arc.phases.map((phase, i) => (
          <div class="flex gap-5">
            <div class="flex shrink-0 flex-col items-center">
              <div class="mt-1 h-3 w-3 shrink-0 rounded-full bg-terra"></div>
              {i < content.arc.phases.length - 1 && <div class="mt-1 min-h-[48px] w-0.5 flex-1 bg-warm"></div>}
            </div>
            <div class="pb-8">
              <p class="mb-0.5 font-sans text-xs uppercase tracking-widest text-terra">
                {phase.number}
              </p>
              <h4 class="mb-2 font-serif text-xl text-deep">{phase.title}</h4>
              <p class="text-sm leading-relaxed text-subtle">{phase.body}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="hidden grid-cols-3 gap-8 md:grid">
        {content.arc.phases.map((phase) => (
          <div class="flex flex-col">
            <div class="mb-4 h-3 w-3 rounded-full bg-terra"></div>
            <p class="mb-1 font-sans text-xs uppercase tracking-widest text-terra">
              {phase.number}
            </p>
            <h4 class="mb-3 font-serif text-2xl text-deep">{phase.title}</h4>
            <p class="text-sm leading-relaxed text-subtle">{phase.body}</p>
          </div>
        ))}
      </div>
    </div>

    <p class="mx-auto mt-16 max-w-2xl text-center font-serif text-xl font-light italic leading-[1.5] text-deep md:mt-20 md:text-2xl">
      {content.closing}
    </p>
  </div>
</section>
