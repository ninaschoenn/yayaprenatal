---
import type { HomeContent } from '../data/home-content';

interface Props {
  content: HomeContent['coaching'];
}

const { content } = Astro.props;
---

<section class="bg-cream px-4 py-16 md:px-12 md:py-24">
  <div class="mx-auto max-w-3xl">
    <p class="mb-4 font-sans text-xs uppercase tracking-widest text-terra">
      {content.eyebrow}
    </p>

    <h2 class="mb-6 font-serif text-3xl leading-tight text-ink md:text-5xl">
      {content.titlePrefix}<br />
      <em class="italic text-terra">{content.titleAccent}</em>
    </h2>

    <p class="mb-12 max-w-[700px] text-base leading-relaxed text-subtle md:text-lg">
      {content.intro}
    </p>

    <div class="relative mb-10 w-full max-w-[700px]" id="coaching-carousel">
      <button
        type="button"
        id="carousel-prev"
        class="group absolute top-1/2 left-0 z-10 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-pearl/78 text-subtle/45 shadow-sm ring-1 ring-warm/70 backdrop-blur-sm transition-all duration-300 hover:bg-pearl hover:text-terra hover:shadow-md active:scale-95 md:h-11 md:w-11"
        aria-label={content.labels.previous}
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 transition-transform duration-300 group-hover:-translate-x-0.5 md:h-6 md:w-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
        </svg>
      </button>

      <button
        type="button"
        id="carousel-next"
        class="group absolute top-1/2 right-0 z-10 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-pearl/78 text-subtle/45 shadow-sm ring-1 ring-warm/70 backdrop-blur-sm transition-all duration-300 hover:bg-pearl hover:text-terra hover:shadow-md active:scale-95 md:h-11 md:w-11"
        aria-label={content.labels.next}
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-0.5 md:h-6 md:w-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
      </button>

      <div class="min-h-[320px] overflow-hidden px-14 md:min-h-[220px] md:px-14" role="region" aria-label={content.labels.region}>
        {content.dialogues.map((item, i) => (
          <div
            class={`coaching-slide absolute inset-x-14 flex flex-col gap-2 transition-all duration-700 ease-in-out ${i === 0 ? 'opacity-100' : 'pointer-events-none opacity-0'}`}
            data-index={i}
            aria-hidden={i === 0 ? 'false' : 'true'}
          >
            <div class="flex justify-start">
              <div class="max-w-[85%] rounded-[2rem] rounded-bl-[0.7rem] bg-deep px-5 py-4 text-cream shadow-sm">
                <p class="mb-1.5 font-sans text-[10px] uppercase tracking-widest text-cream/50">
                  {content.labels.thought}
                </p>
                <p class="font-serif text-[17px] italic leading-snug">
                  &bdquo;{item.thought}&ldquo;
                </p>
              </div>
            </div>

            <div class="flex justify-end">
              <div class="max-w-[85%] rounded-[2rem] rounded-br-[0.7rem] bg-terra px-5 py-4 text-pearl shadow-sm">
                <p class="mb-1.5 font-sans text-[10px] uppercase tracking-widest text-pearl/50">
                  {content.labels.coach}
                </p>
                <p class="text-[15px] leading-relaxed">
                  {item.response}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-6 flex justify-center gap-2">
        {content.dialogues.map((_, i) => (
          <button
            type="button"
            class={`coaching-dot h-2 w-2 rounded-full transition-colors duration-300 ${i === 0 ? 'bg-terra' : 'bg-warm'}`}
            data-index={i}
            aria-label={`${content.labels.dotPrefix} ${i + 1}`}
            aria-current={i === 0 ? 'true' : 'false'}
          />
        ))}
      </div>
    </div>

    <div class="w-full max-w-[700px] rounded-[2rem] rounded-l-[0.6rem] border-l-[3px] border-terra bg-pearl px-6 py-6">
      <p class="text-base leading-relaxed text-ink">
        {content.note}
      </p>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.coaching-slide');
  const dots = document.querySelectorAll('.coaching-dot');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');
  let current = 0;

  function showSlide(index: number) {
    slides.forEach((slide, i) => {
      const el = slide as HTMLElement;
      if (i === index) {
        el.classList.remove('opacity-0', 'pointer-events-none');
        el.classList.add('opacity-100');
        el.setAttribute('aria-hidden', 'false');
      } else {
        el.classList.remove('opacity-100');
        el.classList.add('opacity-0', 'pointer-events-none');
        el.setAttribute('aria-hidden', 'true');
      }
    });
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-terra', i === index);
      dot.classList.toggle('bg-warm', i !== index);
      dot.setAttribute('aria-current', i === index ? 'true' : 'false');
    });
    current = index;
  }

  function nextSlide() {
    showSlide((current + 1) % slides.length);
  }

  function prevSlide() {
    showSlide((current - 1 + slides.length) % slides.length);
  }

  nextBtn?.addEventListener('click', () => {
    nextSlide();
  });
  prevBtn?.addEventListener('click', () => {
    prevSlide();
  });

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      showSlide(Number((dot as HTMLElement).dataset.index));
    });
  });

  const carousel = document.getElementById('coaching-carousel');
  let touchStartX = 0;
  let touchEndX = 0;

  carousel?.addEventListener(
    'touchstart',
    (e) => {
      touchStartX = e.changedTouches[0].screenX;
    },
    { passive: true },
  );

  carousel?.addEventListener(
    'touchend',
    (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          nextSlide();
        } else {
          prevSlide();
        }
      }
    },
    { passive: true },
  );
</script>
