---
import { getLanguageLinks, getNavLinks, pageRoutes, type Locale, type PageKey, uiCopy } from '../data/i18n';
import { site } from '../data/site';

interface Props {
  locale: Locale;
  pageKey: PageKey;
}

const { locale, pageKey } = Astro.props;

const navLinks = getNavLinks(locale);
const languageLinks = getLanguageLinks(pageKey);
const labels = uiCopy[locale].nav;
---

<header class="sticky top-0 z-50 border-b border-warm/50 bg-cream/90 backdrop-blur-md">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 md:px-12 md:py-6">
    <a href={pageRoutes[locale].home} class="no-underline">
      <img
        src={site.branding.logoPath}
        alt="Yaya Prenatal"
        width="2000"
        height="2000"
        loading="eager"
        decoding="async"
        class="h-[55px] w-auto md:h-[70px]"
      />
    </a>

    <div class="hidden items-center gap-9 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-[14px] uppercase tracking-wider text-subtle no-underline transition-colors duration-200 hover:text-terra"
        >
          {link.label}
        </a>
      ))}

      <div
        class="flex items-center gap-1 rounded-full border border-warm bg-pearl px-1.5 py-1"
        aria-label={labels.languageSwitcherLabel}
      >
        {languageLinks.map((link) => {
          const isActive = link.locale === locale;

          return (
            <a
              href={link.href}
              lang={link.lang}
              hreflang={link.lang}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'rounded-full px-3 py-1 text-[11px] font-medium uppercase tracking-[1.5px] no-underline transition-colors duration-200',
                isActive ? 'bg-terra text-pearl' : 'text-subtle hover:text-terra',
              ]}
            >
              {link.label}
            </a>
          );
        })}
      </div>
    </div>

    <button
      id="mobile-menu-btn"
      type="button"
      class="flex flex-col gap-1.5 p-2 -mr-2 md:hidden"
      aria-label={labels.menuOpenLabel}
      aria-controls="mobile-menu"
      aria-expanded="false"
      data-open-label={labels.menuOpenLabel}
      data-close-label={labels.menuCloseLabel}
    >
      <span class="block h-[1.5px] w-5 bg-deep transition-transform duration-200"></span>
      <span class="block h-[1.5px] w-5 bg-deep transition-opacity duration-200"></span>
      <span class="block h-[1.5px] w-3.5 bg-deep transition-transform duration-200"></span>
    </button>
  </nav>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 top-[57px] z-[60] hidden md:hidden"
  aria-hidden="true"
  style="background-color: #C4856C;"
>
  <div class="flex h-full flex-col items-center justify-center gap-10 pb-20">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="mobile-nav-link font-serif text-[28px] font-light tracking-wider text-cream no-underline"
      >
        {link.label}
      </a>
    ))}

    <div
      class="mt-2 flex items-center gap-2 rounded-full border border-cream/35 px-2 py-2"
      aria-label={labels.languageSwitcherLabel}
    >
      {languageLinks.map((link) => {
        const isActive = link.locale === locale;

        return (
          <a
            href={link.href}
            lang={link.lang}
            hreflang={link.lang}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'rounded-full px-4 py-1.5 text-[12px] font-medium uppercase tracking-[1.5px] no-underline transition-colors duration-200',
              isActive ? 'bg-cream text-deep' : 'text-cream/85 hover:text-cream',
            ]}
          >
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</div>

<script is:inline>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const links = document.querySelectorAll('.mobile-nav-link');
  const openLabel = btn?.getAttribute('data-open-label') ?? 'Open menu';
  const closeLabel = btn?.getAttribute('data-close-label') ?? 'Close menu';

  const closeMenu = () => {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-hidden', 'true');
    btn?.setAttribute('aria-expanded', 'false');
    btn?.setAttribute('aria-label', openLabel);
    document.body.classList.remove('overflow-hidden');
  };

  const openMenu = () => {
    menu?.classList.remove('hidden');
    menu?.setAttribute('aria-hidden', 'false');
    btn?.setAttribute('aria-expanded', 'true');
    btn?.setAttribute('aria-label', closeLabel);
    document.body.classList.add('overflow-hidden');
  };

  btn?.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      closeMenu();
      return;
    }

    openMenu();
  });

  links.forEach((link) => {
    link.addEventListener('click', () => {
      closeMenu();
    });
  });

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeMenu();
    }
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768) {
      closeMenu();
    }
  });
</script>
