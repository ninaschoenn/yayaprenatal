---
import type { HomeContent } from '../data/home-content';

interface Props {
  id: string;
  content: HomeContent['about'];
}

const { id, content } = Astro.props;
const introParagraphs = content.paragraphs.slice(0, -1);
const finalParagraph = content.paragraphs.at(-1);
---

<section id={id} class="bg-pearl px-4 py-16 md:px-12 md:py-24">
  <div class="mx-auto max-w-5xl">
    <p class="mb-4 font-sans text-xs uppercase tracking-widest text-terra">
      {content.eyebrow}
    </p>

    <h2 class="mb-12 font-serif text-3xl leading-tight text-ink md:text-5xl">
      {content.title}
    </h2>

    <div class="flex flex-col gap-8 md:flex-row md:gap-16">
      <div class="h-[400px] w-full shrink-0 overflow-hidden rounded-lg md:h-[520px] md:w-[300px]">
        <picture>
          <source
            type="image/webp"
            srcset="/images/about-nina-640.webp 640w, /images/about-nina-960.webp 960w"
            sizes="(min-width: 768px) 300px, 100vw"
          />
          <img
            src="/images/about-nina-960.jpg"
            srcset="/images/about-nina-640.jpg 640w, /images/about-nina-960.jpg 960w"
            sizes="(min-width: 768px) 300px, 100vw"
            alt={content.imageAlt}
            width="960"
            height="1290"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover object-center brightness-[1.05] contrast-[0.85] saturate-[0.95] sepia-[0.08]"
          />
        </picture>
      </div>

      <div>
        <h3 class="mt-0 mb-6 font-serif text-[28px] font-light text-deep md:text-[32px]">
          {content.subtitle}
        </h3>

        {introParagraphs.map((paragraph) => (
          <p class="mb-4 text-[15px] font-light leading-[1.9] text-subtle">
            {paragraph}
          </p>
        ))}

        {finalParagraph && (
          <p class="mb-4 text-[15px] font-light leading-[1.9] text-subtle">
            {finalParagraph}{' '}
            <em class="italic text-terra">{content.practiceName}</em>
          </p>
        )}

        <p class="mb-6 text-[15px] font-normal leading-[1.9] text-deep">
          {content.closing}
        </p>

        <div class="rounded-md bg-cream p-4 md:p-5">
          <p class="mb-2 text-[12px] font-medium text-deep">{content.credentialsLabel}</p>
          <p class="text-[13px] font-light leading-[1.8] text-subtle">
            {content.credentials.map((credential) => (
              <>
                {credential}
                <br />
              </>
            ))}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
