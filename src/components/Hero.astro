---
import type { HomeContent } from '../data/home-content';

interface Props {
  content: HomeContent['hero'];
  contactId: string;
}

const { content, contactId } = Astro.props;
---

<section class="mx-auto flex max-w-7xl flex-col items-center gap-8 px-4 py-12 md:min-h-[80vh] md:flex-row md:gap-12 md:px-12 md:py-20">
  <div class="max-w-full flex-1 text-center md:max-w-[600px] md:text-left">
    <p class="mb-6 text-[12px] font-medium uppercase tracking-[3px] text-terra">
      {content.eyebrow}
    </p>

    <h1 class="mb-8 font-serif font-light leading-[1.1] text-deep">
      <span class="block text-[32px] md:text-[52px]">{content.title.line1}</span>
      <span class="block text-[32px] md:text-[52px]">
        {content.title.line2Prefix && <>{content.title.line2Prefix} </>}
        <em class="italic text-terra">{content.title.line2Accent}</em>
        {content.title.line2Suffix}
      </span>
      <span class="mt-2 block text-[22px] font-light text-subtle md:text-[32px]">
        {content.title.line3}
      </span>
    </h1>

    <div class="mb-4 max-w-[480px] text-base font-light leading-[1.8] text-subtle md:text-lg">
      {content.bullets.map((bullet) => (
        <p>{bullet}</p>
      ))}
    </div>

    <p class="mb-12 max-w-[480px] text-base font-medium leading-[1.8] text-deep md:text-lg">
      {content.lead}
    </p>

    <a
      href={`#${contactId}`}
      class="inline-block bg-terra px-12 py-[18px] text-[13px] font-medium uppercase tracking-[2px] text-pearl no-underline transition-colors duration-300 hover:bg-deep"
    >
      {content.ctaLabel}
    </a>
  </div>

  <div class="relative h-[280px] w-full overflow-hidden rounded-[160px_160px_20px_20px] md:h-[50vh] md:w-[38%]">
    <picture>
      <source
        type="image/webp"
        srcset="/images/hero-nina-720.webp 720w, /images/hero-nina-1200.webp 1200w"
        sizes="(min-width: 768px) 38vw, 100vw"
      />
      <img
        src="/images/hero-nina-1200.jpg"
        srcset="/images/hero-nina-720.jpg 720w, /images/hero-nina-1200.jpg 1200w"
        sizes="(min-width: 768px) 38vw, 100vw"
        alt={content.imageAlt}
        width="1200"
        height="1600"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="h-full w-full object-cover object-top brightness-[1.05] contrast-[0.85] saturate-[0.95] sepia-[0.08]"
      />
    </picture>
    <div class="pointer-events-none absolute inset-0 opacity-[0.07] mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 256 256%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27noise%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.9%27 numOctaves=%274%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23noise)%27/%3E%3C/svg%3E'); background-size: 128px 128px;"></div>
  </div>
</section>
