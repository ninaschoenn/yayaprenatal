---
import type { HomeContent } from '../data/home-content';

interface Props {
  id: string;
  content: HomeContent['packages'];
}

const { id, content } = Astro.props;
---

<section id={id} class="bg-deep px-4 py-16 md:px-12 md:py-24">
  <div class="mx-auto max-w-5xl">
    <p class="mb-4 font-sans text-xs uppercase tracking-widest text-blush">
      {content.eyebrow}
    </p>

    <h2 class="mb-12 font-serif text-3xl leading-tight text-cream md:text-5xl">
      {content.titlePrefix} <em class="italic text-terra">{content.titleAccent}</em>
    </h2>

    <div class="mb-5 max-w-md rounded-lg border-t-[3px] border-blush bg-white/[0.05] p-6 md:p-7">
      <p class="mb-3 font-sans text-[10px] uppercase tracking-widest text-blush">{content.introOffer.label}</p>
      <h3 class="mb-1 font-serif text-2xl font-light text-cream md:text-[28px]">{content.introOffer.title}</h3>
      <p class="mb-4 text-2xl font-light text-terra">{content.introOffer.price}</p>
      <p class="text-[13px] font-light leading-[1.8] text-blush">
        {content.introOffer.details.map((detail) => (
          <>
            {detail}
            <br />
          </>
        ))}
      </p>
    </div>

    <p class="mt-12 mb-4 font-sans text-xs uppercase tracking-widest text-blush">
      {content.introEyebrow}
    </p>

    <p class="mb-6 max-w-[700px] text-sm font-light leading-relaxed text-cream/70">
      {content.introText}
    </p>

    <div class="relative flex max-w-[700px] flex-col rounded-lg border-t-[3px] border-terra bg-terra/20 p-6 ring-1 ring-terra/40 md:p-7">
      <div class="absolute -top-3 right-4">
        <span class="rounded-full bg-terra px-3 py-1 text-[9px] font-semibold uppercase tracking-[1.5px] text-pearl">
          {content.featuredBadge}
        </span>
      </div>

      <p class="mt-1 mb-3 font-sans text-[10px] uppercase tracking-widest text-terra">{content.primaryOffer.label}</p>
      <h3 class="mb-1 font-serif text-2xl font-light text-cream md:text-[28px]">{content.primaryOffer.title}</h3>
      <p class="mb-1 text-3xl font-light text-terra md:text-4xl">
        {content.primaryOffer.price} <span class="text-lg">{content.primaryOffer.priceSuffix}</span>
      </p>
      <p class="mb-1 text-[13px] font-light text-cream/60">{content.primaryOffer.duration}</p>
      <p class="mb-4 text-[12px] font-light text-cream/40">{content.primaryOffer.savings}</p>
      <p class="flex-1 text-[13px] font-light leading-[1.8] text-cream/90">
        {content.primaryOffer.details.map((detail) => (
          <>
            {detail}
            <br />
          </>
        ))}
      </p>
      <p class="mt-4 border-t border-cream/10 pt-4 text-[12px] font-light italic text-cream/50">
        {content.primaryOffer.note}
      </p>
    </div>

    <p class="mt-12 mb-4 font-sans text-xs uppercase tracking-widest text-blush">
      {content.oneOffEyebrow}
    </p>

    <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
      {content.oneOffOffers.map((offer) => (
        <div class={`flex flex-col rounded-lg border-t-2 bg-white/[0.03] p-4 md:p-5 ${offer.accent}`}>
          <h3 class="mb-1 font-serif text-lg font-light text-cream md:text-xl">{offer.title}</h3>
          <p class="mb-3 text-lg font-light text-terra">{offer.price}</p>
          <p class="flex-1 text-[12px] font-light leading-[1.7] text-blush/70">
            {offer.details.map((detail) => (
              <>
                {detail}
                <br />
              </>
            ))}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
