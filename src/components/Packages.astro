---
import { introOffer, oneOffOffers, primaryOffer } from '../data/offers';
---

<section id="paket" class="bg-deep py-16 md:py-24 px-4 md:px-12">
  <div class="max-w-5xl mx-auto">
    <p class="text-blush text-xs uppercase tracking-widest font-sans mb-4">
      Das Angebot
    </p>

    <h2 class="font-serif text-3xl md:text-5xl text-cream leading-tight mb-12">
      Finde deinen Weg zu <em class="text-terra italic">Yaya.</em>
    </h2>

    <!-- Erstgespräch -->
    <div class="bg-white/[0.05] rounded-lg p-6 md:p-7 border-t-[3px] border-blush mb-5 max-w-md">
      <p class="text-blush text-[10px] uppercase tracking-widest font-sans mb-3">{introOffer.label}</p>
      <h3 class="font-serif text-cream text-2xl md:text-[28px] font-light mb-1">{introOffer.title}</h3>
      <p class="text-terra text-2xl font-light mb-4">{introOffer.price}</p>
      <p class="text-blush text-[13px] leading-[1.8] font-light">
        {introOffer.details.map((detail) => (
          <>
            {detail}
            <br />
          </>
        ))}
      </p>
    </div>

    <!-- Complete Care -->
    <p class="text-blush text-xs uppercase tracking-widest font-sans mb-4 mt-12">
      Das Paket
    </p>

    <p class="text-cream/70 text-sm font-light leading-relaxed max-w-xl mb-6">
      Die umfassendste Form der Begleitung — für Frauen, die tiefer schauen wollen.
    </p>

    <div class="bg-terra/20 rounded-lg p-6 md:p-7 border-t-[3px] border-terra flex flex-col relative ring-1 ring-terra/40 max-w-2xl">
      <div class="absolute -top-3 right-4">
        <span class="bg-terra text-pearl text-[9px] font-semibold tracking-[1.5px] uppercase px-3 py-1 rounded-full">
          Empfehlung
        </span>
      </div>

      <p class="text-terra text-[10px] uppercase tracking-widest font-sans mb-3 mt-1">{primaryOffer.label}</p>
      <h3 class="font-serif text-cream text-2xl md:text-[28px] font-light mb-1">{primaryOffer.title}</h3>
      <p class="text-terra text-3xl md:text-4xl font-light mb-1">
        {primaryOffer.price} <span class="text-lg">{primaryOffer.priceSuffix}</span>
      </p>
      <p class="text-cream/60 text-[13px] font-light mb-1">{primaryOffer.duration}</p>
      <p class="text-cream/40 text-[12px] font-light mb-4">{primaryOffer.savings}</p>
      <p class="text-cream/90 text-[13px] leading-[1.8] font-light flex-1">
        {primaryOffer.details.map((detail) => (
          <>
            {detail}
            <br />
          </>
        ))}
      </p>
      <p class="text-cream/50 text-[12px] font-light italic mt-4 pt-4 border-t border-cream/10">
        {primaryOffer.note}
      </p>
    </div>

    <!-- Einzelleistungen -->
    <p class="text-blush text-xs uppercase tracking-widest font-sans mb-4 mt-12">
      Einzelleistungen
    </p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {oneOffOffers.map((offer) => (
        <div class={`bg-white/[0.03] rounded-lg p-4 md:p-5 border-t-2 ${offer.accent} flex flex-col`}>
          <h3 class="font-serif text-cream text-lg md:text-xl font-light mb-1">{offer.title}</h3>
          <p class="text-terra text-lg font-light mb-3">{offer.price}</p>
          <p class="text-blush/70 text-[12px] leading-[1.7] font-light flex-1">
            {offer.details.map((detail) => (
              <>
                {detail}
                <br />
              </>
            ))}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
