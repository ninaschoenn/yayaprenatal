---
import type { HomeContent } from '../data/home-content';

interface Props {
  id: string;
  content: HomeContent['packages'];
}

const { id, content } = Astro.props;
---

<section id={id} class="bg-deep px-4 py-16 md:px-12 md:py-24">
  <div class="mx-auto max-w-5xl">
    <p class="mb-4 font-sans text-xs uppercase tracking-widest text-blush">
      {content.eyebrow}
    </p>

    <h2 class="mb-12 font-serif text-3xl leading-tight text-cream md:text-5xl">
      {content.titlePrefix} <em class="italic text-terra">{content.titleAccent}</em>
    </h2>

    <div class="mb-16 max-w-md rounded-[1.8rem] border-t-[3px] border-blush bg-white/[0.05] p-6 md:mb-20 md:p-7">
      <p class="mb-3 font-sans text-[10px] uppercase tracking-widest text-blush">{content.introOffer.label}</p>
      <h3 class="mb-1 font-serif text-2xl font-light text-cream md:text-[28px]">{content.introOffer.title}</h3>
      <p class="mb-4 text-2xl font-light text-terra">{content.introOffer.price}</p>
      <p class="text-[13px] font-light leading-[1.8] text-blush">
        {content.introOffer.details.map((detail) => (
          <>
            {detail}
            <br />
          </>
        ))}
      </p>
      {content.introOffer.cta && (
        <a
          href={content.introOffer.cta.href}
          class="mt-5 inline-flex items-center justify-center rounded-full bg-blush px-5 py-2.5 text-[12px] font-semibold uppercase tracking-[1.5px] text-deep transition-colors hover:bg-cream"
        >
          {content.introOffer.cta.label}
        </a>
      )}
    </div>

    <p class="mb-4 font-sans text-xs uppercase tracking-widest text-blush">
      {content.introEyebrow}
    </p>
    <p class="mb-8 max-w-[700px] font-serif text-xl font-light italic leading-[1.5] text-cream/90 md:text-2xl">
      {content.primaryOffer.tagline}
    </p>
    <p class="mb-8 max-w-[700px] text-sm font-light leading-relaxed text-cream/70">
      {content.introText}
    </p>

    <div class="relative flex max-w-[760px] flex-col rounded-[2rem] border-t-[3px] border-terra bg-terra/20 p-7 ring-1 ring-terra/40 md:p-10">
      <p class="mt-1 mb-3 font-sans text-[10px] uppercase tracking-widest text-terra">{content.primaryOffer.label}</p>
      <h3 class="mb-2 font-serif text-3xl font-light text-cream md:text-[36px]">{content.primaryOffer.title}</h3>
      <p class="mb-1 text-3xl font-light text-terra md:text-5xl">
        {content.primaryOffer.price} <span class="text-lg md:text-xl">{content.primaryOffer.priceSuffix}</span>
      </p>
      <p class="mb-1 text-[13px] font-light text-cream/60">{content.primaryOffer.duration}</p>
      <p class="mb-5 text-[12px] font-light text-cream/40">{content.primaryOffer.savings}</p>
      <p class="flex-1 text-[14px] font-light leading-[1.9] text-cream/90">
        {content.primaryOffer.details.map((detail) => (
          <>
            {detail}
            <br />
          </>
        ))}
      </p>
      {content.primaryOffer.note && (
        <p class="mt-4 border-t border-cream/10 pt-4 text-[12px] font-light italic text-cream/50">
          {content.primaryOffer.note}
        </p>
      )}
      {content.primaryOffer.cta && (
        <a
          href={content.primaryOffer.cta.href}
          class="mt-6 inline-flex items-center justify-center self-start rounded-full bg-terra px-7 py-3 text-[12px] font-semibold uppercase tracking-[1.5px] text-pearl transition-colors hover:bg-pearl hover:text-terra"
        >
          {content.primaryOffer.cta.label}
        </a>
      )}
    </div>

    <div class="mt-16 md:mt-24">
      <p class="mb-3 font-sans text-[11px] uppercase tracking-widest text-blush/70">
        {content.oneOffEyebrow}
      </p>
      <p class="mb-6 max-w-[640px] text-[13px] font-light leading-relaxed text-cream/50">
        {content.oneOffIntro}
      </p>

      <div class="grid grid-cols-1 gap-2 md:grid-cols-2 md:gap-3">
        {content.oneOffOffers.map((offer) => (
          <div class="flex flex-col rounded-xl bg-white/[0.025] px-4 py-3.5 ring-1 ring-white/[0.06] transition-colors hover:bg-white/[0.04]">
            <div class="flex items-baseline justify-between gap-3">
              <h3 class="font-serif text-[15px] font-light text-cream/90">{offer.title}</h3>
              <p class="shrink-0 font-serif text-[15px] font-light text-terra">{offer.price}</p>
            </div>
            <p class="mt-1.5 text-[11px] font-light leading-[1.65] text-blush/55">
              {offer.details.map((detail, i) => (
                <>
                  {detail}
                  {i < offer.details.length - 1 && <br />}
                </>
              ))}
            </p>
            {offer.cta && (
              <a
                href={offer.cta.href}
                class="mt-3 inline-flex items-center self-start text-[10px] font-semibold uppercase tracking-[1.5px] text-terra transition-colors hover:text-cream"
              >
                {offer.cta.label} →
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
