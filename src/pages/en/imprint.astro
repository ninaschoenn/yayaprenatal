---
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { getAlternateLinks, uiCopy } from '../../data/i18n';
import { site } from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  locale="en"
  title="Imprint — Yaya Prenatal"
  description="Imprint and legal information for the Yaya Prenatal practice in Berlin Friedrichshain."
  alternates={getAlternateLinks('imprint')}
>
  <Header locale="en" pageKey="imprint" />
  <main class="px-4 py-16 md:px-12 md:py-24">
    <article class="mx-auto max-w-2xl">
      <p class="mb-4 font-sans text-xs uppercase tracking-widest text-terra">
        {uiCopy.en.legalEyebrow}
      </p>
      <h1 class="mb-6 font-serif text-4xl leading-tight text-ink md:text-5xl">
        Imprint
      </h1>

      <p class="mb-16 rounded-md border border-warm bg-cream px-5 py-4 text-sm leading-[1.8] text-subtle">
        This English version is provided for clarity. The German version remains legally authoritative.
      </p>

      <div class="text-[15px] leading-[1.8] text-subtle">
        <section>
          <hr class="border-warm" />
          <h2 class="mt-8 mb-2 font-serif text-xl text-ink md:text-2xl">
            Information according to Section 5 TMG
          </h2>
          <p>
            {site.legalContact.displayName}<br />
            {site.legalContact.title}<br />
            {site.legalContact.brand}
          </p>
          <p class="mt-3">
            {site.legalContact.street}<br />
            {site.legalContact.postalCode} {site.legalContact.city}<br />
            {site.legalContact.country}
          </p>
        </section>

        <section class="mt-12">
          <hr class="border-warm" />
          <h2 class="mt-8 mb-2 font-serif text-xl text-ink md:text-2xl">
            Contact
          </h2>
          <p>
            Phone:
            <a href={site.legalContact.phoneHref} class="text-terra underline transition-colors hover:text-deep">
              {site.legalContact.phone}
            </a><br />
            Email:
            <a href={site.legalContact.emailHref} class="text-terra underline transition-colors hover:text-deep">
              {site.legalContact.email}
            </a>
          </p>
        </section>

        <section class="mt-12">
          <hr class="border-warm" />
          <h2 class="mt-8 mb-2 font-serif text-xl text-ink md:text-2xl">
            Professional title and professional regulations
          </h2>
          <p>
            Professional title: Heilpraktikerin<br />
            Granted in: Germany
          </p>
          <p class="mt-3">
            Supervisory authority:<br />
            Gesundheitsamt Friedrichshain-Kreuzberg, Berlin
          </p>
          <p class="mt-3">
            License to practice medicine pursuant to Section 1 paragraph 1 of the German Heilpraktikergesetz,
            issued by Gesundheitsamt Lichtenberg, Berlin.
          </p>
          <p class="mt-3">
            The following professional regulations apply:<br />
            German Heilpraktikergesetz and the First Implementing Regulation to the Heilpraktikergesetz.
          </p>
        </section>

        <section class="mt-12">
          <hr class="border-warm" />
          <h2 class="mt-8 mb-2 font-serif text-xl text-ink md:text-2xl">
            VAT
          </h2>
          <p>
            Exempt from VAT according to Section 4 No. 14 UStG (medical treatment in the field of human medicine).
          </p>
        </section>

        <section class="mt-12">
          <hr class="border-warm" />
          <h2 class="mt-8 mb-2 font-serif text-xl text-ink md:text-2xl">
            Additional qualifications
          </h2>
          <ul class="mt-2 list-inside list-disc space-y-1">
            <li>Certified nutrition counselor</li>
            <li>Training in systemic coaching</li>
          </ul>
        </section>

        <section class="mt-12">
          <hr class="border-warm" />
          <h2 class="mt-8 mb-2 font-serif text-xl text-ink md:text-2xl">
            Responsible for content according to Section 18 paragraph 2 MStV
          </h2>
          <p>
            {site.legalContact.displayName}<br />
            {site.legalContact.street}<br />
            {site.legalContact.postalCode} {site.legalContact.city}
          </p>
        </section>

        <section class="mt-12">
          <hr class="border-warm" />
          <h2 class="mt-8 mb-2 font-serif text-xl text-ink md:text-2xl">
            Dispute resolution
          </h2>
          <p>
            The European Commission provides a platform for online dispute resolution:
            <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer" class="text-terra underline transition-colors hover:text-deep">
              https://ec.europa.eu/consumers/odr/
            </a>
          </p>
          <p class="mt-3">
            We are neither willing nor obliged to participate in dispute resolution proceedings before a consumer arbitration board.
          </p>
        </section>

        <section class="mt-12">
          <hr class="border-warm" />
          <h2 class="mt-8 mb-2 font-serif text-xl text-ink md:text-2xl">
            Liability for content
          </h2>
          <p>
            As a service provider, we are responsible for our own content on these pages according to general law. However, under Sections 8 to 10 TMG, we are not obliged to monitor transmitted or stored third-party information or investigate circumstances that indicate unlawful activity.
          </p>
          <p class="mt-3">
            Obligations to remove or block the use of information under general law remain unaffected. Liability in this respect is only possible from the time we become aware of a specific legal violation. If we become aware of such violations, we will remove the relevant content immediately.
          </p>
        </section>

        <section class="mt-12">
          <hr class="border-warm" />
          <h2 class="mt-8 mb-2 font-serif text-xl text-ink md:text-2xl">
            Liability for links
          </h2>
          <p>
            Our offer contains links to external third-party websites over whose content we have no influence. Therefore, we cannot accept any liability for this external content. The respective provider or operator of the linked pages is always responsible for their content. The linked pages were checked for possible legal violations at the time of linking. No unlawful content was identifiable at that time.
          </p>
        </section>

        <section class="mt-12">
          <hr class="border-warm" />
          <h2 class="mt-8 mb-2 font-serif text-xl text-ink md:text-2xl">
            Copyright
          </h2>
          <p>
            The content and works created by the site operator on these pages are subject to German copyright law. Reproduction, editing, distribution, or any kind of use outside the limits of copyright law requires the written consent of the respective author or creator. Downloads and copies of this page are only permitted for private, non-commercial use.
          </p>
        </section>

        <section class="mt-12">
          <hr class="border-warm" />
          <h2 class="mt-8 mb-2 font-serif text-xl text-ink md:text-2xl">
            Image credits
          </h2>
          <p>
            Photography:
            <a href="https://edmehravaran.com" target="_blank" rel="noopener noreferrer" class="text-terra underline transition-colors hover:text-deep">
              Ed Mehravaran
            </a>
          </p>
        </section>

        <section class="mt-12">
          <hr class="border-warm" />
          <p class="mt-8 font-serif text-sm leading-[1.8] text-subtle italic">
            Yaya Prenatal offers holistic pregnancy support as a complement to medical prenatal care. Our services do not replace treatment by doctors or midwives.
          </p>
        </section>
      </div>
    </article>
  </main>
  <Footer locale="en" />
</BaseLayout>
